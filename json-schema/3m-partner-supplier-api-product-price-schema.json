{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/3m/refs/heads/main/json-schema/3m-partner-supplier-api-product-price-schema.json",
  "title": "ProductPrice",
  "description": "Pricing information for a specific 3M product",
  "type": "object",
  "properties": {
    "productId": {
      "type": "string",
      "description": "Unique product identifier",
      "example": "PROD-12345"
    },
    "unitPrice": {
      "type": "number",
      "description": "Partner-negotiated unit price",
      "example": 24.99
    },
    "currency": {
      "type": "string",
      "description": "Currency code (ISO 4217)",
      "example": "USD"
    },
    "pricingTier": {
      "type": "string",
      "description": "Pricing tier applied to this partner",
      "example": "partner"
    },
    "effectiveDate": {
      "type": "string",
      "format": "date",
      "description": "Date when this pricing becomes effective",
      "example": "2025-01-01"
    },
    "expirationDate": {
      "type": "string",
      "format": "date",
      "description": "Date when this pricing expires",
      "example": "2025-12-31"
    }
  }
}